# =====================================================
# UniEvent PHP Slim Backend - Environment Configuration
# Copy this file to ".env" and fill in your real values.
# =====================================================

# --- Database (MySQL via PDO) ---
# For local XAMPP/MAMP, defaults shown below usually work.
# For TiDB Cloud, replace with your TiDB gateway host + port 4000.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=unievent_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# --- JWT ---
# IMPORTANT: change this to a long random string before deployment.
JWT_SECRET=unievent_secret_key_2026_freshdev
JWT_EXPIRES_HOURS=24

# --- App ---
APP_ENV=development
APP_DEBUG=true

# --- CORS ---
# Use * for local dev. In production, set to your frontend URL, e.g.
#   CORS_ORIGIN=https://unievent.vercel.app
CORS_ORIGIN=*

# --- TiDB Cloud (optional) ---
# If using TiDB Cloud, set DB_SSL=true so PDO enables TLS.
# DB_SSL=true
# DB_SSL_CA=/etc/ssl/cert.pem
